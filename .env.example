# =============================================================================
# Workstream Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Only GITHUB_PAT and GITHUB_USERNAME are required for the core PR dashboard.
# All other integrations are optional -- enable what you need.
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED -- GitHub
# ---------------------------------------------------------------------------
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your-github-username

# ---------------------------------------------------------------------------
# OPTIONAL -- GitLab (for cross-platform PR tracking)
# ---------------------------------------------------------------------------
# GITLAB_PAT=glpat-xxxxxxxxxxxxxxxxxxxx
# GITLAB_URL=https://gitlab.com
# GITLAB_USERNAME=your-gitlab-username

# ---------------------------------------------------------------------------
# OPTIONAL -- Jira (for sprint tracking, task counts, yearly stats)
# ---------------------------------------------------------------------------
# JIRA_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=your-jira-api-token
# JIRA_PROJECTS=PROJ1,PROJ2
# JIRA_ACCOUNT_NAME=Your Full Name
# JIRA_BOARD_PROJECTS=PROJ1,PROJ2

# ---------------------------------------------------------------------------
# OPTIONAL -- Google Calendar (for Today's Agenda widget)
# ---------------------------------------------------------------------------
# Follow docs/CONFIGURATION.md for OAuth setup instructions.
# GOOGLE_CREDENTIALS_PATH=./google_credentials.json
# GOOGLE_TOKEN_PATH=./google_token.json
# GOOGLE_CALENDAR_IDS=primary,team-calendar@group.calendar.google.com

# ---------------------------------------------------------------------------
# OPTIONAL -- AI Code Review Providers
# ---------------------------------------------------------------------------
# At least one provider is needed for the AI review feature.
# AI_CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxx
# AI_CLAUDE_MODEL=claude-sonnet-4-20250514
# AI_GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxx
# AI_GEMINI_MODEL=gemini-2.0-flash
# AI_OLLAMA_URL=http://localhost:11434
# AI_OLLAMA_MODEL=llama3

# ---------------------------------------------------------------------------
# OPTIONAL -- Display & Behavior
# ---------------------------------------------------------------------------
# Your name shown in the dashboard greeting
# DISPLAY_NAME=Your Name
# Polling interval in seconds (default: 300 = 5 minutes)
# POLL_INTERVAL=300

# ---------------------------------------------------------------------------
# OPTIONAL -- Paths (defaults are project-relative, rarely need changing)
# ---------------------------------------------------------------------------
# DB_PATH=./data.db
# LOG_DIR=./logs
# REPOS_YAML=./repos.yaml

# ---------------------------------------------------------------------------
# OPTIONAL -- Repo Filtering
# ---------------------------------------------------------------------------
# Comma-separated repos to exclude from review requests
# IGNORED_REPOS=org/test-repo,org/sandbox
# Default repos for intelligence collection (if not specified per-scan)
# INTELLIGENCE_DEFAULT_REPOS=org/repo1,org/repo2
