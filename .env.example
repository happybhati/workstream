# Workstream environment configuration
# Copy to .env and fill in your values: cp .env.example .env
# NEVER commit the .env file — it is git-ignored.

# --- GitHub (required for PR dashboard) ---
GITHUB_PAT=ghp_your_token_here
GITHUB_USERNAME=your_username

# --- GitLab (optional) ---
# GITLAB_PAT=glpat-your_token
# GITLAB_URL=https://gitlab.com
# GITLAB_USERNAME=your_username

# --- Jira (optional) ---
# JIRA_URL=https://your-org.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your_jira_token
# JIRA_PROJECTS=PROJ1,PROJ2

# --- Polling ---
POLL_INTERVAL=300

# --- AI Review Providers (all optional) ---
# AI_CLAUDE_API_KEY=sk-ant-your_key
# AI_GEMINI_API_KEY=your_gemini_key
# AI_OLLAMA_URL=http://localhost:11434
