# Workstream environment configuration
# Copy to .env and fill in your values: cp .env.example .env
# NEVER commit the .env file — it is git-ignored.

# --- GitHub (required for PR dashboard) ---
GITHUB_PAT=ghp_your_token_here
GITHUB_USERNAME=your_username

# --- GitLab (optional) ---
# GITLAB_PAT=glpat-your_token
# GITLAB_URL=https://gitlab.com
# GITLAB_USERNAME=your_username

# --- Jira (optional) ---
# JIRA_URL=https://your-org.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your_jira_token
# JIRA_PROJECTS=PROJ1,PROJ2

# --- Server ---
# WORKSTREAM_HOST=127.0.0.1       # Bind address (default: 127.0.0.1, use 0.0.0.0 for network)
# WORKSTREAM_PORT=8080             # Listen port (default: 8080)
# WORKSTREAM_AUTH_TOKEN=           # Set a secret to require auth (disabled when empty)

# --- Polling ---
POLL_INTERVAL=300

# --- AI Review Providers (all optional, configure any or all) ---
# AI_OPENAI_API_KEY=sk-your_openai_key
# AI_OPENAI_MODEL=gpt-4o                      # default: gpt-4o
# AI_CLAUDE_API_KEY=sk-ant-your_key
# AI_CLAUDE_MODEL=claude-sonnet-4-20250514          # default: claude-sonnet-4-20250514
# AI_GEMINI_API_KEY=your_gemini_key
# AI_GEMINI_MODEL=gemini-2.0-flash             # default: gemini-2.0-flash
# AI_OLLAMA_URL=http://localhost:11434          # auto-detected, no key needed
# AI_OLLAMA_MODEL=llama3                        # default: llama3
