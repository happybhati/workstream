# Template for creating the workstream-secrets Secret.
# DO NOT commit this file with real values.
#
# Option A — apply this template after filling in values:
#   kubectl apply -f k8s-secret.yaml
#
# Option B — create from the command line (preferred):
#   kubectl create secret generic workstream-secrets \
#     --from-literal=GITHUB_PAT=ghp_your_token \
#     --from-literal=GITHUB_USERNAME=your_username \
#     --from-literal=POLL_INTERVAL=300
apiVersion: v1
kind: Secret
metadata:
  name: workstream-secrets
type: Opaque
stringData:
  GITHUB_PAT: "ghp_your_token_here"
  GITHUB_USERNAME: "your_username"
  # JIRA_URL: "https://your-org.atlassian.net"
  # JIRA_EMAIL: "you@example.com"
  # JIRA_API_TOKEN: "your_jira_token"
  POLL_INTERVAL: "300"
